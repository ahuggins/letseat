{
    "manifest_version": 3,
    "name": "LetsEat - Add Recipes",
    "description": "Preview and add recipes from any page into your LetsEat account.",
    "version": "0.1.1",
    "minimum_chrome_version": "114",
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Add to LetsEat",
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png"
        }
    },
    "options_page": "options.html",
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://recipes.andrewhuggins.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
    ]
}